# Smart CA — root Docker Compose overrides
# cp .env.example .env
#
# Read automatically by `docker compose` for ${VAR} substitution in docker-compose.yml.
# Every variable has a safe default baked into docker-compose.yml, so
# `docker compose up --build` works even without this file.
#
# NEVER commit the real .env file. NEVER put secrets in git.
#
# For native (non-Docker) development, use the per-app files instead:
#   Go/.env.example    -> copy to Go/.env
#   saas/.env.example  -> copy to saas/.env

# --- PostgreSQL (used by the "db" and "api" services) ---
DB_USER=smartca
DB_PASSWORD=smartca
DB_NAME=smartca

# --- Gemini AI (used by the "api" service only; never sent to the browser) ---
# Provider selector: gemini | mock. Leave as "mock" if you don't have a Gemini key.
AI_PROVIDER=mock
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
