# Smart CA — root Docker Compose overrides
# cp .env.example .env
#
# IMPORTANT (Docker):
#   docker compose ONLY reads this root .env file for ${VAR} substitution.
#   Go/.env and saas/.env are for native (non-Docker) development and are
#   NOT injected into containers. Copy AI keys here for Docker Gemini.
#
# NEVER commit the real .env file. NEVER put secrets in git.
#
# Helper (PowerShell):  powershell -File scripts/sync-docker-ai-env.ps1
# Helper copies GEMINI_* / AI_PROVIDER from Go/.env into this root .env.

# --- PostgreSQL (used by the "db" and "api" services) ---
DB_USER=smartca
DB_PASSWORD=smartca
DB_NAME=smartca

# --- Gemini AI (used by the "api" service only; never sent to the browser) ---
# Provider selector: gemini | openai | ollama | mock.
# If GEMINI_API_KEY is set, the API prefers Gemini even when AI_PROVIDER=mock,
# unless you explicitly Save/Remove settings to mock in the AI Settings UI.
AI_PROVIDER=gemini
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Prefer official "latest" aliases; the UI also discovers models via the Gemini API.
GEMINI_MODEL=gemini-flash-latest
# Stable secret for encrypting saved API keys (independent of DB password changes).
AI_SETTINGS_SECRET=smartca-ai-settings
