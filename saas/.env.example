# Smart CA frontend — copy to .env for local overrides
# cp .env.example .env
#
# Browser-visible variables must be prefixed with VITE_ (Vite inlines them at build time).
# Never put secrets in VITE_* variables.

# Purpose: REST API base path used by src/services/httpClient.ts
# Required: no (code default http://localhost:8080/api/v1 when unset/empty)
# Native development: absolute URL to Go on the host
# Docker production image build: /api/v1 (same-origin; nginx proxies to Compose service "api")
# Security: not a secret
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Purpose: product display name
# Required: no (default "Smart CA")
VITE_APP_NAME=Smart CA
