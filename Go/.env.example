# Smart CA Backend — copy to .env and adjust as needed
# cp .env.example .env
#
# Do not commit real .env files. Do not bake .env into Docker images.

# --- Application ---
# Purpose: environment label (development|production|test)
# Required: no (default development)
# Native: development | Docker: production
APP_ENV=development

# Purpose: bind address for HTTP listener
# Required: no (default 0.0.0.0)
# Native: 0.0.0.0 | Docker: 0.0.0.0
HTTP_HOST=0.0.0.0

# Purpose: HTTP listen port
# Required: no (default 8080)
# Native: 8080 | Docker internal: 8080 (not published to host by default Compose)
HTTP_PORT=8080

# Purpose: comma-separated browser Origin allowlist for CORS (never *)
# Required: yes (validated non-empty; * rejected)
# Note: localhost and 127.0.0.1 are different origins.
# Native Vite: include both :5173 origins
# Docker (same-origin /api via nginx on :8080): include published web origins
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Optional alias (takes precedence when set):
# FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Docker Compose example:
# FRONTEND_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Purpose: slog level
# Required: no (default info) — debug|info|warn|error
LOG_LEVEL=info

# Purpose: opaque session TTL (rememberMe extends to 7d in code)
# Required: no (default 30m; minimum 1m)
SESSION_TTL=30m

# Purpose: allow POST /api/v1/demo/reset for super_admin
# Required: no (defaults to true when APP_ENV is development-like)
DEMO_RESET_ENABLED=true

# --- Database ---
# Purpose: PostgreSQL database configuration
# Required: yes (for production)
# Format: host=localhost port=5432 user=smartca password=smartca dbname=smartca sslmode=disable
# Keep these credentials aligned with root /.env.example and docker-compose.yml defaults.
DB_HOST=localhost
DB_PORT=5432
DB_USER=smartca
DB_PASSWORD=smartca
DB_NAME=smartca
DB_SSLMODE=disable
# Optional: max open connections (default 25)
DB_MAX_OPEN_CONNS=25
# Optional: max idle connections (default 5)
DB_MAX_IDLE_CONNS=5
# Optional: connection max lifetime in minutes (default 5)
DB_CONN_MAX_LIFETIME=5

# --- Gemini AI (server-side ONLY — never expose to React / Vite) ---
# Purpose: Google Gemini API key for Smart CA AI endpoints
# Required: only when AI_PROVIDER=gemini
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Purpose: Gemini model id (default gemini-2.5-flash; gemini-flash-latest also works)
GEMINI_MODEL=gemini-2.5-flash
# Purpose: HTTP timeout for Gemini calls
GEMINI_TIMEOUT=45s
# Purpose: default max output tokens
GEMINI_MAX_TOKENS=2048
# Purpose: provider selector — mock (offline/default) | gemini (requires GEMINI_API_KEY)
AI_PROVIDER=mock
